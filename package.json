{
  "name": "wallrus",
  "module": "src/cli.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --bun vite dev",
    "build": "bun --bun vite build",
    "build:mobile": "WALLRUS_ADAPTER=static bun --bun vite build",
    "preview": "bun --bun vite preview",
    "serve": "bun run src/cli.ts serve",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:e2e": "bunx playwright test",
    "lint": "bunx eslint .",
    "lint:fix": "bunx eslint . --fix",
    "format": "bunx prettier --write .",
    "format:check": "bunx prettier --check .",
    "gates": "bun run check && bun test && bunx eslint . && bunx prettier --check .",
    "check": "bunx svelte-kit sync && bunx svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "bunx svelte-kit sync && bunx svelte-check --tsconfig ./tsconfig.json --watch",
    "db:generate": "bunx drizzle-kit generate",
    "db:studio": "bunx drizzle-kit studio",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@sveltejs/kit": "2.61.1",
    "@tigorhutasuhut/telemetry-js": "^1.10.0",
    "bits-ui": "2.18.1",
    "commander": "14.0.3",
    "croner": "10.0.1",
    "drizzle-orm": "0.45.2",
    "jose": "6.2.3",
    "lucide-svelte": "1.0.1",
    "sharp": "0.34.5",
    "svelte": "5.55.9",
    "sveltekit-superforms": "2.30.1",
    "uuidv7": "1.2.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "3.0.10",
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.60.0",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/svelte": "5.3.1",
    "@types/bun": "latest",
    "drizzle-kit": "0.31.10",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-svelte": "3.17.1",
    "globals": "17.6.0",
    "happy-dom": "20.9.0",
    "lefthook": "2.1.8",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "4.0.1",
    "prettier-plugin-tailwindcss": "0.8.0",
    "svelte-adapter-bun": "1.0.1",
    "svelte-check": "4.4.8",
    "tailwindcss": "4.3.0",
    "typescript-eslint": "8.59.4",
    "vite": "8.0.14"
  },
  "peerDependencies": {
    "typescript": "6.0.3"
  }
}
