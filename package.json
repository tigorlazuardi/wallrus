    "@types/bun": "latest",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-svelte": "3.17.1",
    "globals": "17.6.0",
    "lefthook": "2.1.8",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "4.0.1",
